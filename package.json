{
  "name": "nanoclaw-workspace-ui",
  "version": "1.0.0",
  "description": "Visual file manager for NanoClaw agent workspaces — browse, edit and manage files from any browser, with built-in Cloudflare tunnel for remote access",
  "type": "module",
  "bin": {
    "nanoclaw-workspace-ui": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/",
    "client/",
    "assets/"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "dev": "node bin/cli.js --no-tunnel",
    "lint": "node --check bin/cli.js server/index.js server/tunnel.js"
  },
  "keywords": [
    "nanoclaw",
    "ai-agent",
    "workspace",
    "file-manager",
    "cloudflare-tunnel",
    "developer-tools",
    "claude",
    "llm",
    "agent-workspace"
  ],
  "author": {
    "name": "Ido Navarro",
    "url": "https://github.com/navarroido"
  },
  "license": "MIT",
  "homepage": "https://github.com/navarroido/nanoclaw-workspace-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/navarroido/nanoclaw-workspace-ui.git"
  },
  "bugs": {
    "url": "https://github.com/navarroido/nanoclaw-workspace-ui/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  }
}
